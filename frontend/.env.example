# Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# Website Configuration
NEXT_PUBLIC_SITE_NAME=Bahan Bangunan Store
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_WHATSAPP_NUMBER=your_whatsapp_number

# SEO Configuration
NEXT_PUBLIC_DEFAULT_META_TITLE=Bahan Bangunan Store - Jual Bahan Material Bangunan Terlengkap
NEXT_PUBLIC_DEFAULT_META_DESCRIPTION=Toko bahan bangunan online terpercaya. Jual berbagai material bangunan berkualitas dengan harga terbaik. Pesan sekarang!

# Development Configuration
NODE_ENV=development
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
NEXT_PUBLIC_SHOW_DEBUG_INFO=true
